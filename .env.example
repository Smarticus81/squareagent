# ── Required ────────────────────────────────────────────────
# Supabase / Postgres connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# OpenAI key (for voice agent realtime API)
OPENAI_API_KEY=sk-...

# ── Square OAuth (for venue onboarding) ─────────────────────
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_APPLICATION_SECRET=sq0csp-...

# ── Optional ────────────────────────────────────────────────
# JWT_SECRET=some-random-secret          # defaults to dev secret locally
# STRIPE_SECRET_KEY=sk_test_...          # only needed for subscriptions
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_POS_ONLY=price_...
# STRIPE_PRICE_INVENTORY_ONLY=price_...
# STRIPE_PRICE_COMPLETE=price_...
