{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "start": "node artifacts/api-server/dist/index.cjs",
    "build:railway": "node ./scripts/build-railway.mjs",
    "start:railway": "node artifacts/api-server/dist/index.cjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
