{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "workspaceapi-server-production-2c14.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "workspaceapi-server-production-2c14.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "workspaceapi-server-production-2c14.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascApiKeyId": "REPLACE_BEFORE_SUBMIT",
        "ascApiKeyIssuerId": "REPLACE_BEFORE_SUBMIT"
      }
    }
  }
}
